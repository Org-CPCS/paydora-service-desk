# Telegram bot token for the Master Bot (@MasterPaydoraServiceBot)
MASTER_BOT_TOKEN=your_master_bot_token_here

# Comma-separated Telegram user IDs of Super Admins (can manage tenants via Master Bot)
SUPER_ADMIN_IDS=your_telegram_user_id_here

# Set to "true" to start the app without connecting to Telegram (local dev)
DRY_RUN=true

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/paydora-support
